# dbt environment variables for {{cookiecutter.project_slug}}.
#
# Copy this file to dbt/.env and fill in your credentials.
# dbt/.env is gitignored — never commit it.
#
# Usage:
#   cp dbt/.env.example dbt/.env
#   # edit dbt/.env with your values
#   source dbt/.env
#
# Tip: install direnv (https://direnv.net/) to load this automatically
# when you cd into the dbt/ directory.

# ── dbt profile directory ─────────────────────────────────────────────────────
# Tells dbt to use the profiles.yml in this directory instead of ~/.dbt/profiles.yml.
# Keep this as-is — the path is relative to the repo root.
DBT_PROFILES_DIR=./dbt

# ── DEV workspace ─────────────────────────────────────────────────────────────
# Workspace URL (without https://): e.g. adb-mdp-dlz-{{cookiecutter.databricks_workspace_role}}-dev-euw.azuredatabricks.net
DBT_DATABRICKS_HOST_DEV=

# SQL warehouse HTTP path: found in Databricks UI → SQL Warehouses → <warehouse> → Connection details
DBT_DATABRICKS_HTTP_PATH_DEV=

# Personal access token: Databricks UI → User Settings → Developer → Access Tokens → Generate new token
# Alternatively use OAuth: see https://docs.databricks.com/en/dev-tools/dbt.html#authentication
DBT_DATABRICKS_TOKEN_DEV=

# ── TEST workspace ────────────────────────────────────────────────────────────
DBT_DATABRICKS_HOST_TEST=
DBT_DATABRICKS_HTTP_PATH_TEST=
DBT_DATABRICKS_TOKEN_TEST=

# ── PROD workspace ────────────────────────────────────────────────────────────
# Prefer OAuth M2M or a service principal token for prod — avoid personal tokens.
DBT_DATABRICKS_HOST_PROD=
DBT_DATABRICKS_HTTP_PATH_PROD=
DBT_DATABRICKS_TOKEN_PROD=
